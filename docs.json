{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Grounds Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Welcome",
        "pages": [
          "index",
          "licensing"
        ]
      },
      {
        "tab": "Plugins",
        "pages": [
          "plugins/index",
          {
            "group": "Config System",
            "pages": [
              "plugins/config-system/index",
              "plugins/config-system/config-plugin",
              "plugins/config-system/config-api",
              "plugins/config-system/runtime-behavior"
            ]
          }
        ]
      },
      {
        "tab": "Platform",
        "pages": [
          "platform/index",
          {
            "group": "Containers",
            "pages": [
              "platform/containers/index",
              {
                "group": "Available Containers",
                "pages": [
                  "platform/containers/dev-container-node",
                  "platform/containers/paper",
                  "platform/containers/velocity"
                ]
              },
              "platform/containers/adding-a-new-container"
            ]
          },
          {
            "group": "Charts",
            "pages": [
              "platform/charts/index",
              {
                "group": "Available Charts",
                "pages": []
              },
              "platform/charts/adding-a-new-chart"
            ]
          },
          {
            "group": "Minecraft Identity Provider for Keycloak",
            "pages": [
              "platform/keycloak-minecraft-idp/index",
              "platform/keycloak-minecraft-idp/installation",
              "platform/keycloak-minecraft-idp/configuration"
            ]
          }
        ]
      },
      {
        "tab": "APIs",
        "pages": [
          "apis/index"
        ]
      },
      {
        "tab": "Development",
        "pages": [
          {
            "group": "Gradle Plugin",
            "pages": [
              "development/gradle-plugin/index",
              "development/gradle-plugin/usage"
            ]
          },
          {
            "group": "Conventions",
            "pages": [
              "development/naming-conventions",
              "development/logging-conventions"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://grounds.gg",
          "icon": "house"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/groundsgg"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Discord",
      "href": "https://discord.gg/zNQkU8vm3Z"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/groundsgg",
      "discord": "https://discord.gg/zNQkU8vm3Z"
    }
  }
}
